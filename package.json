{
  "name": "feeder",
  "version": "1.0.0",
  "private": true,
  "description": "Generate Atom and RSS feeds from structured Firecrawl extractions.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "update": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "tsx test/integration.test.ts",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "feed": "^6.0.0",
    "firecrawl": "^4.30.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^4.1.10"
  }
}
